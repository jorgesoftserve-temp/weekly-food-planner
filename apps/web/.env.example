# Copy this to apps/web/.env.local (never committed) and fill in.
# After `cd packages/supabase && supabase start`, run `supabase status` and
# copy the anon + service_role keys it prints.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for /api/admin/* endpoints (local-dev / Postman only).
# Set this to any string; the same value goes into Postman's `admin_key` variable.
ADMIN_API_KEY=change-me-please

# Optional: enables the Claude-API food-group classifier for user-created ingredients (v2.0 Phase 0).
# Leave empty to disable classification gracefully (food_group_source stays 'unset').
ANTHROPIC_API_KEY=
