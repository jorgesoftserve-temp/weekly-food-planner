{
  "name": "@weekly-food-planner/supabase",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION=1 vitest run",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:migration:new": "supabase migration new",
    "db:gen:types": "supabase gen types typescript --local --schema public > src/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.2",
    "@tanstack/react-query": "^5.62.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@weekly-food-planner/test-utils": "workspace:*",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
